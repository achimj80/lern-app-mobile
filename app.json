{
  "expo": {
    "name": "LernApp",
    "slug": "lern-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffbeb"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lernapp.mobile",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Für Sprachaufnahmen bei Diktaten",
        "NSCameraUsageDescription": "Zum Fotografieren von geschriebenen Diktaten"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fffbeb"
      },
      "package": "com.lernapp.mobile"
    }
  }
}
